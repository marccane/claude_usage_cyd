// secrets.h — copy to secrets.h and fill in. (secrets.h is git-ignored.)
#pragma once
#include <stddef.h>  // size_t

// One or more WiFi networks. On boot (and after a drop) the device scans, then
// connects to the strongest of these that is actually in range. List as many as
// you like; order doesn't matter — selection is by signal strength.
struct WifiCred { const char *ssid; const char *pass; };

static const WifiCred WIFI_CREDS[] = {
  {"your-wifi",       "your-password"},
  {"second-wifi",     "second-password"},
  // {"phone-hotspot", "hotspot-password"},
};
static const size_t WIFI_CRED_COUNT = sizeof(WIFI_CREDS) / sizeof(WIFI_CREDS[0]);
